PORT=3000

# Kick streaming credentials
KICK_RTMP_URL=rtmp://fa7d1000693a.global-contribute.live-video.net/app
KICK_STREAM_KEY=sk_us_xxxxxxxxxxxxxxx

# Dashboard origin for CORS (e.g. https://dashboard.incaslop.online)
ALLOWED_ORIGIN=https://dashboard.incaslop.online

# Secret token — Dashboard sends this as: Authorization: Bearer <API_TOKEN>
API_TOKEN=replace_with_a_random_secret

# Chromium binary path (default works on AlmaLinux after bootstrap.sh)
CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Xvfb display number
DISPLAY_NUM=:99

# Stream resolution and encoding
STREAM_WIDTH=1920
STREAM_HEIGHT=1080
STREAM_FPS=30
VIDEO_BITRATE=4500k
MAXRATE=4500k
BUFSIZE=9000k
GOP=60
PRESET=veryfast
AUDIO_BITRATE=192k

# URL to stream on startup (leave blank to start stopped)
DEFAULT_URL=https://sinadef.incaslop.online/iframe

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=